NODE_ENV=production
PORT=3000

# Shared secret between helios-gateway and helios-hermes-adapter.
# Do not commit the real value.
HERMES_API_KEY=

# Hermes profile/configuration.
HERMES_PROFILE=helios
HERMES_CWD=/home/hermeswebui/.hermes/profiles/helios/workspace/helios

# Hermes WebUI connection.
HERMES_WEBUI_BASE_URL=https://hermes.servicios.escala365.com
HERMES_WEBUI_PASSWORD=

# Optional timeout.
HERMES_TIMEOUT_MS=30000

# Optional local session map.
HERMES_SESSION_STORE_PATH=/tmp/helios-hermes-sessions.json

# Optional model override.
# Leave empty if Hermes profile helios already has the correct default model.
HERMES_MODEL=
HERMES_MODEL_PROVIDER=

# Telemetry and debugging panel credentials
DEBUG_USERNAME=democoi1
DEBUG_PASSWORD=democoi1
DEBUG_TOKEN=
